# III — Config: ortam değişkenleri (kod içi secret yok)
# Kopyala: copy .env.example .env

NODE_ENV=development
PORT=3000
PUBLIC_API_URL=http://localhost:3000

# CORS (virgülle ayrılmış; boş bırakılırsa dev'de Expo/localhost, prod'da PUBLIC_API_URL)
# CORS_ORIGINS=http://localhost:8081,http://192.168.1.10:8081

# PostgreSQL (IV — backing service)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_app_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT — production'da zorunlu, güçlü rastgele değer
JWT_SECRET=degistir_guclu_bir_sirre
JWT_EXPIRES_IN=7d

# Google Gemini (AI)
GEMINI_API_KEY=

# Redis (IV)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_URL=redis://:sifre@localhost:6379

# XI — Logs
LOG_LEVEL=debug

# VIII — Concurrency (1 = tek süreç, >1 cluster)
WEB_CONCURRENCY=1

# IX — Graceful shutdown timeout (ms)
SHUTDOWN_TIMEOUT_MS=10000

# Redis TTL (saniye, isteğe bağlı)
# REDIS_TTL_ANSWER_SECONDS=1800
# REDIS_TTL_NUTRITION_PLAN_SECONDS=3600
