{
  "expo": {
    "name": "Proje2",
    "slug": "Proje2",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#ffffff" },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafınızı seçmek için galeri erişimine ihtiyaç var.",
          "cameraPermission": "Profil fotoğrafı çekmek için kamera erişimine ihtiyaç var."
        }
      ]
    ]
  }
}
